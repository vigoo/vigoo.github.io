[83.126, "o", "\u001b[50;2H\u001b[38;5;3;49m⠙\u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25h\u001b[53;2H"]
[83.278, "o", "\u001b[2;2H## Repo structure at a higher level                                                                                                                                                                                                        \u001b[3;2H                                                                                                                                                                                                    \u001b[4;2H-                                                                \u001b[5;2H\u001b[1mMacros layer (\u001b[22m\u001b[38;5;11;48;5;8mtest-r-macro\u001b[1m\u001b[39;49m)\u001b[22m                                \u001b[6;2HParses attributes and transforms user test code.     \u001b[7;2H-                                                        \u001b[8;2H\u001b[1mCore engine (\u001b[22m\u001b[38;5;11;48;5;8mtest-r-core\u001b[1m\u001b[39;49m)\u001b[22m                                              \u001b[9;2HHandles test discovery/registration, execution, output capture, scheduling, IPC, reporting, async support,\u001b[9;109Hbenchmarking,\u001b[9;123Hetc.\u001b[10;2H-       "]
[83.278, "o", "                                                                         \u001b[11;2H\u001b[1mPublic crate (\u001b[22m\u001b[38;5;11;48;5;8mtest-r\u001b[1m\u001b[39;49m)\u001b[22m                                                           \u001b[12;2HRe-exports the user-facing API and features.                                                                      \u001b[13;2H-                                                                                \u001b[14;2H\u001b[1mCargo tool (\u001b[22m\u001b[38;5;11;48;5;8mcargo-test-r\u001b[1m\u001b[39;49m)\u001b[22m                             \u001b[15;2HAdds Cargo-side support/utilities.                \u001b[16;2H-                                                                     \u001b[17;2H\u001b[1mDocs (\u001b[22m\u001b[38;5;11;48;5;8mbook/\u001b[1m\u001b[39;49m)\u001b[22m                                   \u001b[18;2HThis seems to be the best place to understand intended usage and features.      \u001b[19;2H                                                                             \u001b[20;2H---                                                                                                "]
[83.279, "o", "                                    \u001b[21;2H                                                                                 \u001b[22;2H## What it does not support                                            \u001b[23;2H                                               \u001b[24;2HAccording to the docs, notable limitations include:                           \u001b[25;2H                                               \u001b[26;2H- \u001b[1mdoctests are not supported\u001b[22m                                                       \u001b[27;2H- output capture has limitations when combined with\u001b[27;54Hboth:\u001b[28;2H    - parallel execution                                                            \u001b[29;2H    - dependency injection                     \u001b[30;2H                                                                                    \u001b[31;2H---                                            \u001b[32;2H                                                                                        \u001b[33;2H## Overall summary                              \u001b[34;2H            "]
[83.279, "o", "                                                                                                                                                     \u001b[35;2HThis repo is about building a \u001b[1mmore capable Rust testing ecosystem\u001b[22m centered around\u001b[35;84H\u001b[38;5;11;48;5;8mtest-r\u001b[39;49m:\u001b[36;2H                                                                                                     \u001b[37;2H- familiar like standard Rust tests             \u001b[38;2H- more powerful for real-world and large-scale test suites                                          \u001b[39;2H- especially strong for:                        \u001b[40;2H    - async tests                                                                                              \u001b[41;2H    - shared fixtures/dependencies              \u001b[42;2H    - generated tests                                                                                             \u001b[43;2H    - CI/reporting                              \u001b[44;2H    - advanced execution control                         "]
[83.279, "o", "                                                        \u001b[45;2H                                                \u001b[46;2HIf you want, I can also give you:                                                                     \u001b[47;2H                                                \u001b[48;2H\u001b[38;5;12;49m1. \u001b[39;49ma \u001b[1mtour of each crate\u001b[22m, or                                                                                                                                      \u001b[49;2H\u001b[38;5;12;49m2. \u001b[39;49ma \u001b[1m“how a test-r test actually works under the hood”\u001b[22m explanation.              \u001b[50;2H                      \u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25h\u001b[53;2H"]
[83.389, "o", "\u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25h\u001b[53;2H"]
