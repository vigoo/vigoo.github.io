[126.981, "o", "st-r-macro\u001b[37;21H->\u001b[37;24Hproc-macros\u001b[38;2H├── cargo-test-r   -> cargo-side\u001b[38;35Hhelper/tool\u001b[39;2H├──\u001b[39;6Hexample\u001b[39;21H->\u001b[39;24Hsample\u001b[39;31Hcrate\u001b[40;2H├── \u001b[40;8Hample-tokio\u001b[40;21H->\u001b[40;24Hasync\u001b[40;30Hsample\u001b[40;37Hcrate\u001b[41;2H├── book         \u001b[41;21H->\u001b[41;24Hdocumentation     \u001b[41;47H                    \u001b[42;2H└── github    \u001b[42;18H \u001b[42;21H->\u001b[42;24Hrepo/release/github-relat\u001b[42;50Hd tooling    \u001b[42;66H \u001b[43;2H```              \u001b[43;24H                  \u001b[43;47H                    \u001b[44;2H \u001b[44;4H     \u001b[44;10H       \u001b[44;18H \u001b[44;24H \u001b[44;26H      \u001b[44;33H    \u001b[44;41H \u001b[44;47H \u001b[44;49H       \u001b[44;66H \u001b[45;2HIf you w\u001b[45;11Hnt, I\u001b[45;17Hcan\u001b[45;21Halso\u001b[45;26Hmake:\u001b[45;32H      \u001b[45;41H \u001b[45;47H \u001b[45;49H             \u001b[45;66H \u001b[46;2H                 \u001b[46;24H                  \u001b[46;47H                    \u001b[47;2H- a\u001b[47;6H\u001b[1mclean Mermaid diagram\u001b[48;2H\u001b[22m-\u001b[48;4Ha\u001b[48;6H\u001b[1mdependency graph with arrows\u001b[49;2H\u001b[22m- or a \u001b[1m“how a test file flows through macro -> core -> runner”\u001b[49;65H\u001b[22mdiagram.\u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25h\u001b[53;2H"]
