[168.399, "o", "\u001b[2;2H├── test-r                                  \u001b[3;2H│ \u001b[3;5H ├── re-exports macros from test-r-macro\u001b[4;2H│\u001b[4;6H├──\u001b[4;10Hre-exports\u001b[4;21Hruntime\u001b[4;29Hpieces\u001b[4;36Hfrom\u001b[4;41Htest-r-core\u001b[5;2H│   └──\u001b[5;10Hcore\u001b[5;15Hmodule\u001b[5;26H#\u001b[5;28Hregistration\u001b[5;41HAPI\u001b[5;45Hbridging\u001b[5;54Hmacros\u001b[5;61Hto\u001b[5;64Hcore\u001b[5;69Hruntime\u001b[6;2H│\u001b[7;2H├── cargo-test-r            \u001b[8;2H│\u001b[8;6H└──\u001b[8;10HCLI\u001b[8;14Htool\u001b[8;19Hfor\u001b[8;23Hrunning\u001b[8;31Htest-r\u001b[8;38Hvia\u001b[8;42HCargo\u001b[8;48Hworkflows\u001b[9;2H│   \u001b[9;7H         \u001b[9;17H  \u001b[9;20H          \u001b[9;31H  \u001b[9;34H   \u001b[9;38H        \u001b[9;47H       \u001b[9;55H        \u001b[10;2H├──\u001b[10;6Htest-r-github\u001b[11;2H│   └── generates GitHub\u001b[11;27HActions\u001b[11;35Hworkflow\u001b[11;44Hfiles\u001b[12;2H│  \u001b[12;6H \u001b[12;8H \u001b[12;10H     \u001b[12;16H       \u001b[12;24H       \u001b[13;2H├──\u001b[13;6Htest-r-example\u001b[14;2H│\u001b[14;4H  └── example project\u001b[14;26Husing\u001b[14;32Htest-r\u001b[14;39Hwithout\u001b[14;47Htokio\u001b[15;2H│\u001b[15;4H      \u001b[15;11H  \u001b[15;14H          \u001b["]
[168.399, "o", "15;25H      \u001b[16;2H└──\u001b[16;6Htest-r-example-tokio\u001b[17;2H   \u001b[17;6H└── example project\u001b[17;26Husing\u001b[17;32Htest-r\u001b[17;39Hwith\u001b[17;44Htokio\u001b[18;2H```\u001b[19;2H \u001b[19;4H      \u001b[19;11H   \u001b[19;15H         \u001b[19;25H   \u001b[19;29H    \u001b[19;34H       \u001b[20;2HAnd here\u001b[20;11His \u001b[20;15Hhe dependency relationship\u001b[20;42Hbetween the crates:\u001b[22;2H```tex\u001b[22;9H   \u001b[22;13H    \u001b[22;18H        \u001b[22;27H     \u001b[22;33H    \u001b[22;38H         \u001b[22;48H         \u001b[22;58H   \u001b[22;62H   \u001b[22;66H  \u001b[22;69H          \u001b[22;80H       \u001b[22;88H    \u001b[22;93H       \u001b[22;101H     \u001b[23;16H┌──────────────┐\u001b[24;2H              │  test-r-core │                             \u001b[25;2H       \u001b[25;10H      └──────┬───────┘ \u001b[25;34H  \u001b[25;37H                  \u001b[25;56H   \u001b[25;60H     \u001b[25;66H   \u001b[25;70H         \u001b[25;80H             \u001b[26;23H│\u001b[27;2H       \u001b[27;12H┌──────────┴──────────┐\u001b[28;12H│\u001b[28;34H│\u001b[29;2H┌─────────"]
[168.399, "o", "▼─────────┐  \u001b[29;26H┌───────▼───────┐\u001b[30;2H│\u001b[30;6Htest-r-macro\u001b[30;22H│\u001b[30;26H│\u001b[30;31Htest-r\u001b[30;42H│\u001b[31;2H│ (proc\u001b[31;10Hmacros)     │\u001b[31;26H│\u001b[31;28Hpublic\u001b[31;35Hfacade\u001b[31;42H│\u001b[32;2H└─────────┬─────────┘\u001b[32;26H└───────┬───────┘\u001b[33;2H \u001b[33;4H        │             \u001b[33;34H│\u001b[34;2H \u001b[34;4H        └──────────┬──────────┘\u001b[35;2H \u001b[35;4H                   │        \u001b[36;2H \u001b[36;4H      ┌────────────▼────────────┐\u001b[37;10H│\u001b[37;12Hexample\u001b[37;20H/\u001b[37;22Hexample-tokio\u001b[37;36H│\u001b[38;2H  \u001b[38;5H   \u001b[38;9H └─────────────────────────┘   \u001b[38;41H  \u001b[38;44H      \u001b[38;51H            \u001b[38;64H              \u001b[38;79H   \u001b[38;83H    \u001b[38;88H            \u001b[40;2HOther workspace tools:\u001b[41;2H- cargo-test-r     (stan"]
