[100.971, "o", "\u001b[2;2H\u001b[1m\u001b[38;5;2;49m> \u001b[22mWhat's the current darling version we use?\u001b[3;2H\u001b[39;49mWe\u001b[3;5Hcurrently use \u001b[38;5;11;48;5;8mdarling = \"0.21.3\"\u001b[39;49m.         \u001b[3;48H         \u001b[3;58H   \u001b[3;62H   \u001b[3;66H  \u001b[3;69H          \u001b[3;80H       \u001b[3;88H    \u001b[3;93H       \u001b[3;101H     \u001b[5;2HSource:                                                    \u001b[6;2H                                                 \u001b[7;2H- \u001b[38;5;11;48;5;8mtest-r-macro/Cargo.toml:17\u001b[39;49m                                    \u001b[8;2H                                                                       \u001b[9;2HAlso reflected in \u001b[38;5;11;48;5;8mCargo.lock\u001b[39;49m as the resolved \u001b[38;5;11;48;5;8mdarling\u001b[39;49m package.                                     \u001b[10;2H                                                                                      \u001b[11;2H\u001b[1m\u001b[38;5;2;49m> \u001b[22mIs there a newer one?\u001b[39;49m                                                                                                               \u001b[12;2HYes — a newer version exists.   "]
[100.971, "o", "                                                 \u001b[13;2H                                                                                   \u001b[14;2H- We use: \u001b[38;5;11;48;5;8m0.21.3\u001b[39;49m                               \u001b[15;2H- Latest on crates.io: \u001b[38;5;11;48;5;8m0.23.0\u001b[39;49m                                                                                                       \u001b[16;2H                                                                           \u001b[17;2HOne thing to note:                                                                                                          \u001b[18;2H                                                                                 \u001b[19;2H- \u001b[38;5;11;48;5;8m0.22.0\u001b[39;49m was published and then yanked.                                                                            \u001b[20;2H- \u001b[38;5;11;48;5;8m0.23.0\u001b[39;49m lists an MSRV of \u001b[38;5;11;48;5;8m1.88.0\u001b[39;49m, while \u001b[38;5;11;48;5;8m0.21.3\u001b[39;49m lists \u001b[38;5;11;48;5;8m1.56\u001b[39;49m.                  \u001b[21;2H    "]
